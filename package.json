{
  "name": "inventure-playwright-tests",
  "version": "1.0.0",
  "description": "Playwright E2E tests for Inventure Login Flow",
  "scripts": {
    "test": "playwright test",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:report": "playwright show-report",
    "test:happy": "playwright test tests/happyPath.spec.js",
    "test:ci": "playwright test --reporter=github"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "dotenv": "^16.4.5"
  },
  "main": "playwright.config.js",
  "directories": {
    "test": "tests"
  },
